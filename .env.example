# ======================================
# Async Execution System - Configuration
# ======================================
# Copy this file to .env and update values for your environment.

# ---- Database ----
# Option A: Full connection string (takes priority)
# DATABASE_URL=postgresql+asyncpg://executor_user:executor_password@localhost:5432/executor_db
# Option B: Individual components (used when DATABASE_URL is not set)
POSTGRES_USER=executor_user
POSTGRES_PASSWORD=executor_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=executor_db

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Or override directly:
# REDIS_URL=redis://localhost:6379/0

# ---- Application ----
APP_NAME=Async Execution System
APP_VERSION=1.0.0
DEBUG=false

# ---- Worker ----
WORKER_CONCURRENCY=100
WORKER_HEARTBEAT_INTERVAL=5
WORKER_TIMEOUT=30

# ---- Rate Limiting ----
DEFAULT_MAX_RETRIES=3
DEFAULT_RETRY_BACKOFF=2.0
